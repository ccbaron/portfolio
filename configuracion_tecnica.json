      "path_aliases": {
        "@/*": "./src/*",
        "@/components/*": "./src/components/*",
        "@/stores/*": "./src/stores/*",
        "@/types/*": "./src/types/*"
      }
    },
    "vite_config": {
      "port": 3000,
      "open": true,
      "resolve_aliases": "Coinciden con TypeScript paths"
    }
