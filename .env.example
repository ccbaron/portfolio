# Base URL
NUXT_PUBLIC_BASE_URL=https://ccbaron.com

# Node environment
NODE_ENV=development

# MongoDB — full connection string from MongoDB Atlas
# NUXT_MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority

# Telegram — bot token from @BotFather and the chat_id to receive notifications
# NUXT_TELEGRAM_BOT_TOKEN=
# NUXT_TELEGRAM_CHAT_ID=
