# =============================================================
# Variables de entorno — copiar a .env y rellenar valores reales
# .env NO debe commitearse (añadido a .gitignore)
# =============================================================

# URL pública del sitio
NUXT_PUBLIC_BASE_URL=https://ccbaron.com

# Entorno Node
NODE_ENV=production

# MongoDB — connection string completo (MongoDB Atlas o self-hosted)
NUXT_MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/portfolio?retryWrites=true&w=majority

# Telegram — notificaciones de nuevos mensajes de contacto
# 1. Crea un bot con @BotFather y copia el token
# 2. Envía un mensaje al bot y visita:
#    https://api.telegram.org/bot<TOKEN>/getUpdates para obtener el chat_id
NUXT_TELEGRAM_BOT_TOKEN=
NUXT_TELEGRAM_CHAT_ID=
