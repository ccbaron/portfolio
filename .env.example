# Environment Variables Template
# Copia este archivo como .env.local para desarrollo local

# Base URL del sitio (cambia por tu dominio final)
VITE_BASE_URL=https://ccbaron.dev

# Configuración de build
VITE_BUILD_MODE=production

# Configuración de analytics (para futuro)
# VITE_GA_ID=G-XXXXXXXXXX

# Configuración de EmailJS (para futuro)
# VITE_EMAILJS_SERVICE_ID=your_service_id
# VITE_EMAILJS_TEMPLATE_ID=your_template_id
# VITE_EMAILJS_PUBLIC_KEY=your_public_key

# Configuración de desarrollo
NODE_ENV=development

# Nota: Los archivos .env.local no se suben a Git (están en .gitignore)