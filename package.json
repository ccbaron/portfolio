{
  "name": "ccbaron-portfolio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Portfolio web de ccbaron - Desarrollador Full Stack",
  "scripts": {
    "dev": "vite",
    "dev:force": "vite --force",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "clean": "rm -rf node_modules/.vite node_modules/.tmp dist .vite",
    "fresh": "npm run clean && npm run dev:force"
  },
  "dependencies": {
    "vue": "^3.5.22",
    "vue-router": "^4.6.3",
    "pinia": "^3.0.3",
    "@vueuse/core": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "@vue/eslint-config-typescript": "^14.1.3",
    "eslint": "^9.14.0",
    "eslint-plugin-vue": "^9.29.1",
    "typescript": "~5.9.3",
    "vite": "^7.1.7",
    "vue-tsc": "^3.1.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.15"
  }
}
